{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}
{% block meta_description %}Créez votre espace personnel pour accéder à nos services d'accompagnement.{% endblock %}

{% block content %}
    <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-16 px-4 bg-zinc-50">
        <div class="w-full max-w-md">

            {# ── En-tête ── #}
            <div class="text-center mb-8">
                <a href="{{ path('app_front_page_home') }}" class="inline-flex items-center gap-2 mb-6 group">
                    <div class="w-9 h-9 rounded-xl bg-zinc-900 flex items-center justify-center">
                        <svg class="w-5 h-5 fill-white" viewBox="0 0 16 16" aria-hidden="true">
                            <path d="M8 1L14 5v6l-6 4L2 11V5z"/>
                        </svg>
                    </div>
                    <span class="text-sm font-semibold text-zinc-900 group-hover:text-zinc-600 transition-colors">
                {{ site_name|default('AssocDev') }}
            </span>
                </a>
                <h1 class="text-2xl font-semibold tracking-tight text-zinc-900">Créer un compte</h1>
                <p class="text-sm text-zinc-500 mt-2">
                    Déjà inscrit ?
                    <a href="{{ path('app_login') }}" class="font-medium text-zinc-900 underline underline-offset-2 hover:text-zinc-600 transition-colors">
                        Se connecter
                    </a>
                </p>
            </div>

            {# ── Flash erreur vérification e-mail ── #}
            {% for flash_error in app.flashes('verify_email_error') %}
                <div
                    class="mb-5 flex items-start gap-3 px-4 py-3 rounded-lg border border-red-200 bg-red-50 text-sm text-red-700"
                    role="alert"
                    aria-live="assertive"
                >
                    <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16" aria-hidden="true">
                        <circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 11v.5"/>
                    </svg>
                    <span>{{ flash_error }}</span>
                </div>
            {% endfor %}

            {# ── Carte formulaire ── #}
            <div class="bg-white border border-zinc-200 rounded-2xl shadow-sm p-8">

                {# Erreurs globales du formulaire #}
                {% if registrationForm.vars.errors|length %}
                    <div
                        class="mb-5 flex items-start gap-3 px-4 py-3 rounded-lg border border-red-200 bg-red-50 text-sm text-red-700"
                        role="alert"
                        aria-live="polite"
                    >
                        <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16" aria-hidden="true">
                            <circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 11v.5"/>
                        </svg>
                        <ul class="space-y-0.5 list-none">
                            {% for error in registrationForm.vars.errors %}
                                <li>{{ error.message }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                {{ form_start(registrationForm, {
                    attr: {
                        class: 'space-y-5',
                        novalidate: 'novalidate',
                    }
                }) }}

                {# ── E-mail ── #}
                {% include 'composants/forms/input.html.twig' with {
                    name: 'registration_form[email]',
                    id: 'registration_form_email',
                    label: 'Adresse e-mail',
                    type: 'email',
                    icon: 'mail',
                    placeholder: 'jean@exemple.fr',
                    autocomplete: 'email',
                    required: true,
                    value: registrationForm.email.vars.value|default(''),
                    error: registrationForm.email.vars.errors|length
                    ? registrationForm.email.vars.errors[0].message,
                } %}

                {# ── Mot de passe ── #}
                {% include 'composants/forms/input.html.twig' with {
                    name: 'registration_form[plainPassword]',
                    id: 'registration_form_plainPassword',
                    label: 'Mot de passe',
                    type: 'password',
                    icon: 'lock',
                    autocomplete: 'new-password',
                    required: true,
                    help: '8 caractères minimum, avec au moins une majuscule et un chiffre.',
                    error: registrationForm.plainPassword.vars.errors|length
                    ? registrationForm.plainPassword.vars.errors[0].message,
                } %}

                {# ── Indicateur de force du mot de passe ── #}
                <div aria-hidden="true" id="password-strength-wrap" class="hidden -mt-3">
                    <div class="flex gap-1 mb-1">
                        <span id="ps-bar-1" class="h-1 flex-1 rounded-full bg-zinc-200 transition-colors"></span>
                        <span id="ps-bar-2" class="h-1 flex-1 rounded-full bg-zinc-200 transition-colors"></span>
                        <span id="ps-bar-3" class="h-1 flex-1 rounded-full bg-zinc-200 transition-colors"></span>
                        <span id="ps-bar-4" class="h-1 flex-1 rounded-full bg-zinc-200 transition-colors"></span>
                    </div>
                    <p id="ps-label" class="text-[11px] text-zinc-400"></p>
                </div>

                {# ── CGU ── #}
                {% include 'composants/forms/checkbox.html.twig' with {
                    name: 'registration_form[agreeTerms]',
                    id: 'registration_form_agreeTerms',
                    label: "J'accepte les conditions générales d'utilisation",
                    required: true,
                    value: '1',
                    checked: registrationForm.agreeTerms.vars.checked|default(false),
                    error: registrationForm.agreeTerms.vars.errors|length
                    ? registrationForm.agreeTerms.vars.errors[0].message,
                } %}

                {# Note CGU #}
                <p class="text-xs text-zinc-400 leading-relaxed -mt-2">
                    En créant un compte vous acceptez notre
                    <a href="{{ path('app_front_page_cgu') }}" class="underline underline-offset-2 hover:text-zinc-700 transition-colors" target="_blank">
                        politique de confidentialité
                    </a>
                    et nos
                    <a href="{{ path('app_front_page_cgu') }}" class="underline underline-offset-2 hover:text-zinc-700 transition-colors" target="_blank">
                        conditions d'utilisation
                    </a>.
                </p>

                {# ── Token CSRF (géré par Symfony form_start, on le laisse caché) ── #}
                {{ form_rest(registrationForm) }}

                {# ── Bouton soumission ── #}
                <button
                    type="submit"
                    class="w-full inline-flex items-center justify-center gap-2 h-10 px-5 text-sm font-medium rounded-lg
                       bg-zinc-900 text-white hover:bg-zinc-700 transition-colors
                       focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2
                       disabled:opacity-50 disabled:cursor-not-allowed"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 1L14 5v6l-6 4L2 11V5z"/>
                    </svg>
                    Créer mon compte
                </button>

                {{ form_end(registrationForm) }}

            </div>

            {# ── Pied de page ── #}
            <p class="text-center text-xs text-zinc-400 mt-6">
                Un problème ?
                <a href="{{ path('app_front_page_contact') }}" class="underline underline-offset-2 hover:text-zinc-700 transition-colors">
                    Contactez-nous
                </a>
            </p>

        </div>
    </section>

    {# ── Script indicateur de force du mot de passe ── #}
    <script>
        (function () {
            var input = document.getElementById('registration_form_plainPassword');
            var wrap  = document.getElementById('password-strength-wrap');
            var bars  = [
                document.getElementById('ps-bar-1'),
                document.getElementById('ps-bar-2'),
                document.getElementById('ps-bar-3'),
                document.getElementById('ps-bar-4'),
            ];
            var label = document.getElementById('ps-label');

            if (!input) return;

            var levels = [
                { label: 'Très faible', color: 'bg-red-500',    score: 1 },
                { label: 'Faible',      color: 'bg-orange-400',  score: 2 },
                { label: 'Moyen',       color: 'bg-amber-400',   score: 3 },
                { label: 'Fort',        color: 'bg-emerald-500', score: 4 },
            ];

            function score(v) {
                var s = 0;
                if (v.length >= 8)              s++;
                if (/[A-Z]/.test(v))            s++;
                if (/[0-9]/.test(v))            s++;
                if (/[^A-Za-z0-9]/.test(v))     s++;
                return s;
            }

            input.addEventListener('input', function () {
                var v = input.value;
                if (!v) { wrap.classList.add('hidden'); return; }
                wrap.classList.remove('hidden');

                var s = score(v);
                var lvl = levels[s - 1] || levels[0];

                bars.forEach(function (b, i) {
                    b.className = 'h-1 flex-1 rounded-full transition-colors ' +
                        (i < s ? lvl.color : 'bg-zinc-200');
                });
                label.textContent = lvl.label;
                label.className = 'text-[11px] transition-colors ' + {
                    'bg-red-500':    'text-red-500',
                    'bg-orange-400': 'text-orange-500',
                    'bg-amber-400':  'text-amber-500',
                    'bg-emerald-500':'text-emerald-600',
                }[lvl.color];
            });
        })();
    </script>

{% endblock %}
