{#
Badge component
Usage: {% include 'components/badge.html.twig' with { status: 'delivered' } %}

Statuts disponibles :
  - delivered   → Livré       (vert)
  - processing  → En cours    (bleu)
  - pending     → En attente  (amber)
  - failed      → Échoué      (rouge)
  - cancelled   → Annulé      (zinc)
  - refunded    → Remboursé   (violet)

Paramètres optionnels :
  - label  : surcharge le libellé affiché
  - size   : 'sm' (défaut) | 'md'
#}

{% set size = size|default('sm') %}

{% set config = {
    delivered: {
        label: 'Livré',
        class: 'bg-emerald-50 text-emerald-700 ring-emerald-600/20 dark:bg-emerald-500/10 dark:text-emerald-400 dark:ring-emerald-500/20',
        dot:   'bg-emerald-500',
    },
    processing: {
        label: 'En cours',
        class: 'bg-blue-50 text-blue-700 ring-blue-600/20 dark:bg-blue-500/10 dark:text-blue-400 dark:ring-blue-500/20',
        dot:   'bg-blue-500',
    },
    pending: {
        label: 'En attente',
        class: 'bg-amber-50 text-amber-700 ring-amber-600/20 dark:bg-amber-500/10 dark:text-amber-400 dark:ring-amber-500/20',
        dot:   'bg-amber-500',
    },
    failed: {
        label: 'Échoué',
        class: 'bg-red-50 text-red-700 ring-red-600/20 dark:bg-red-500/10 dark:text-red-400 dark:ring-red-500/20',
        dot:   'bg-red-500',
    },
    cancelled: {
        label: 'Annulé',
        class: 'bg-zinc-100 text-zinc-600 ring-zinc-500/20 dark:bg-zinc-500/10 dark:text-zinc-400 dark:ring-zinc-500/20',
        dot:   'bg-zinc-400',
    },
    refunded: {
        label: 'Remboursé',
        class: 'bg-violet-50 text-violet-700 ring-violet-600/20 dark:bg-violet-500/10 dark:text-violet-400 dark:ring-violet-500/20',
        dot:   'bg-violet-500',
    },
} %}

{% set cfg = config[status]|default({
    label: status|capitalize,
    class: 'bg-zinc-100 text-zinc-600 ring-zinc-500/20 dark:bg-zinc-500/10 dark:text-zinc-400 dark:ring-zinc-500/20',
    dot:   'bg-zinc-400',
}) %}

{% set size_class = size == 'md'
    ? 'px-2.5 py-1 text-xs gap-1.5'
    : 'px-2 py-0.5 text-[11px] gap-1' %}

<span class="inline-flex items-center rounded-full font-medium ring-1 ring-inset {{ cfg.class }} {{ size_class }}">
    <span class="w-1.5 h-1.5 rounded-full shrink-0 {{ cfg.dot }}"></span>
    {{ label|default(cfg.label) }}
</span>
