{#
Topbar component
Usage: {% include 'components/topbar.html.twig' %}
Expects: block `breadcrumbs` optionally overridden in child templates
#}
<header class="shrink-0 flex items-center gap-3 h-12 px-5 bg-white dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800">

    {# Breadcrumb #}
    <nav class="flex-1 flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400 min-w-0">
        <a href="{{ path('app_admin_dashboard_index') }}" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors shrink-0">
            Accueil
        </a>
        {% block breadcrumbs %}
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M6 4l4 4-4 4"/></svg>
        <span class="text-zinc-900 dark:text-zinc-100 font-medium truncate">
                {% block topbar_title %}Dashboard{% endblock %}
            </span>
        {% endblock %}
    </nav>

    {# Search #}
    <div class="relative hidden sm:block">
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16">
            <circle cx="6.5" cy="6.5" r="4.5"/><path d="M10 10l3.5 3.5"/>
        </svg>
        <input
            type="search"
            placeholder="Rechercher…"
            class="h-8 pl-8 pr-3 w-48 text-sm rounded-lg bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900 dark:focus:ring-zinc-100 focus:ring-offset-0 transition"
        >
    </div>

    {# Notifications #}
    <button class="relative flex items-center justify-center w-8 h-8 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16">
            <path d="M8 2a5 5 0 00-5 5v2l-1.5 2h13L13 9V7a5 5 0 00-5-5zM6.5 13a1.5 1.5 0 003 0"/>
        </svg>
        <span class="absolute top-1.5 right-1.5 w-1.5 h-1.5 bg-red-500 rounded-full"></span>
    </button>

    {# Primary action button — override via block #}
    {% block topbar_action %}{% endblock %}

</header>
