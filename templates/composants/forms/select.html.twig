{#
  Composant : form/select.html.twig
  ─────────────────────────────────────────────────────────────
  Paramètres :
    name        (string)        — attribut name + id de base   [requis]
    label       (string)        — libellé visible              [requis]
    options     (array)         — tableau de choix             [requis]
                  Forme simple  : ['valeur1', 'valeur2']
                  Forme avancée : [{value: 'v', label: 'L', disabled: true}]
                  Avec groupes  : [{group: 'Groupe', items: [{value,label}]}]
    value       (string)        — valeur sélectionnée          [optionnel]
    placeholder (string)        — option vide initiale         [optionnel]
    help        (string)        — texte d'aide                 [optionnel]
    error       (string)        — message d'erreur             [optionnel]
    required    (bool)          — défaut : false
    disabled    (bool)          — défaut : false
    multiple    (bool)          — multi-select, défaut : false
    size        (int)           — lignes visibles (multiple)   [optionnel]
    id          (string)        — surcharge l'id               [optionnel]

  Usage :
    {% include 'components/form/select.html.twig' with {
        name: 'status',
        label: 'Statut',
        placeholder: 'Choisir un statut…',
        value: 'active',
        required: true,
        options: [
            { value: 'active',   label: 'Actif' },
            { value: 'inactive', label: 'Inactif' },
            { value: 'pending',  label: 'En attente' },
        ],
        error: form.status.vars.errors|length ? form.status.vars.errors[0].message,
    } %}
#}

{% set _id       = id|default(name) %}
{% set _required = required|default(false) %}
{% set _disabled = disabled|default(false) %}
{% set _multiple = multiple|default(false) %}
{% set _hasError = error is defined and error is not empty %}
{% set _hasHelp  = help is defined and help is not empty %}

{% set _helpId  = _id ~ '-help' %}
{% set _errorId = _id ~ '-error' %}

{% set _described = [] %}
{% if _hasHelp  %}{% set _described = _described|merge([_helpId])  %}{% endif %}
{% if _hasError %}{% set _described = _described|merge([_errorId]) %}{% endif %}

<div class="flex flex-col gap-1.5">

    {# Label #}
    <label
        for="{{ _id }}"
        class="text-sm font-medium text-zinc-700
               {{ _disabled ? 'opacity-50 cursor-not-allowed' : '' }}"
    >
        {{ label }}
        {% if _required %}
            <span class="text-red-500 ml-0.5" aria-hidden="true">*</span>
        {% endif %}
    </label>

    {# Wrapper select avec chevron #}
    <div class="relative">
        <select
            id="{{ _id }}"
            name="{{ _multiple ? name ~ '[]' : name }}"
            {% if _multiple %}multiple{% if size is defined %} size="{{ size }}"{% endif %}{% endif %}
            {% if _required %}required aria-required="true"{% endif %}
            {% if _disabled %}disabled aria-disabled="true"{% endif %}
            {% if _hasError %}aria-invalid="true"{% else %}aria-invalid="false"{% endif %}
            {% if _described is not empty %}aria-describedby="{{ _described|join(' ') }}"{% endif %}
            class="
                w-full h-9 rounded-lg border bg-white text-sm text-zinc-900
                pl-3 {{ _multiple ? 'pr-3 h-auto' : 'pr-9' }}
                focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-zinc-900
                transition-colors appearance-none
                {{ _hasError
                    ? 'border-red-400 focus:ring-red-500 bg-red-50'
                    : 'border-zinc-300 hover:border-zinc-400' }}
                {{ _disabled ? 'opacity-50 cursor-not-allowed bg-zinc-50' : 'cursor-pointer' }}
            "
        >
            {# Option vide / placeholder #}
            {% if placeholder is defined %}
                <option value="" {% if not value is defined or value is empty %}selected{% endif %} disabled>
                    {{ placeholder }}
                </option>
            {% endif %}

            {# Options #}
            {% for option in options %}
                {% if option.group is defined %}
                    {# Groupe d'options #}
                    <optgroup label="{{ option.group }}">
                        {% for item in option.items %}
                            <option
                                value="{{ item.value }}"
                                {% if item.disabled is defined and item.disabled %}disabled{% endif %}
                                {% if _multiple %}
                                    {% if value is iterable and item.value in value %}selected{% endif %}
                                {% else %}
                                    {% if value is defined and item.value == value %}selected{% endif %}
                                {% endif %}
                            >{{ item.label }}</option>
                        {% endfor %}
                    </optgroup>
                {% elseif option is not iterable %}
                    {# Forme simple : tableau de strings #}
                    <option
                        value="{{ option }}"
                        {% if value is defined and option == value %}selected{% endif %}
                    >{{ option }}</option>
                {% else %}
                    {# Forme avancée : {value, label, disabled?} #}
                    <option
                        value="{{ option.value }}"
                        {% if option.disabled is defined and option.disabled %}disabled{% endif %}
                        {% if _multiple %}
                            {% if value is iterable and option.value in value %}selected{% endif %}
                        {% else %}
                            {% if value is defined and option.value == value %}selected{% endif %}
                        {% endif %}
                    >{{ option.label }}</option>
                {% endif %}
            {% endfor %}
        </select>

        {# Chevron (masqué en mode multiple) #}
        {% if not _multiple %}
            <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-zinc-400" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16">
                    <path d="M4 6l4 4 4-4"/>
                </svg>
            </span>
        {% endif %}
    </div>

    {# Aide #}
    {% if _hasHelp %}
        <p id="{{ _helpId }}" class="text-xs text-zinc-500">{{ help }}</p>
    {% endif %}

    {# Erreur #}
    {% if _hasError %}
        <p
            id="{{ _errorId }}"
            class="text-xs text-red-600 flex items-center gap-1"
            role="alert"
            aria-live="polite"
        >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16" aria-hidden="true">
                <circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 11v.5"/>
            </svg>
            {{ error }}
        </p>
    {% endif %}

</div>
