{#
  Composant : form/textarea.html.twig
  ─────────────────────────────────────────────────────────────
  Paramètres :
    name        (string)  — attribut name + id de base         [requis]
    label       (string)  — libellé visible                    [requis]
    value       (string)  — valeur initiale                    [optionnel]
    placeholder (string)  — texte fantôme                      [optionnel]
    help        (string)  — texte d'aide                       [optionnel]
    error       (string)  — message d'erreur                   [optionnel]
    required    (bool)    — défaut : false
    disabled    (bool)    — défaut : false
    readonly    (bool)    — défaut : false
    rows        (int)     — nombre de lignes, défaut : 4
    maxlength   (int)     — limite de caractères               [optionnel]
    id          (string)  — surcharge l'id généré              [optionnel]
    resize      (string)  — 'none' | 'y' (défaut) | 'both'

  Usage :
    {% include 'components/form/textarea.html.twig' with {
        name: 'description',
        label: 'Description',
        rows: 5,
        maxlength: 500,
        required: true,
        help: '500 caractères maximum',
    } %}
#}

{% set _id       = id|default(name) %}
{% set _required = required|default(false) %}
{% set _disabled = disabled|default(false) %}
{% set _readonly = readonly|default(false) %}
{% set _rows     = rows|default(4) %}
{% set _resize   = resize|default('y') %}
{% set _hasError = error is defined and error is not empty %}
{% set _hasHelp  = help is defined and help is not empty %}
{% set _hasMax   = maxlength is defined %}

{% set _helpId  = _id ~ '-help' %}
{% set _errorId = _id ~ '-error' %}
{% set _countId = _id ~ '-count' %}

{% set _described = [] %}
{% if _hasHelp  %}{% set _described = _described|merge([_helpId])  %}{% endif %}
{% if _hasError %}{% set _described = _described|merge([_errorId]) %}{% endif %}
{% if _hasMax   %}{% set _described = _described|merge([_countId]) %}{% endif %}

{% set _resizeClass = {
    'none': 'resize-none',
    'y':    'resize-y',
    'both': 'resize',
}[_resize]|default('resize-y') %}

<div class="flex flex-col gap-1.5">

    {# Label #}
    <label
        for="{{ _id }}"
        class="text-sm font-medium text-zinc-700
               {{ _disabled ? 'opacity-50 cursor-not-allowed' : '' }}"
    >
        {{ label }}
        {% if _required %}
            <span class="text-red-500 ml-0.5" aria-hidden="true">*</span>
        {% endif %}
    </label>

    {# Textarea #}
    <textarea
        id="{{ _id }}"
        name="{{ name }}"
        rows="{{ _rows }}"
        {% if _hasMax %}maxlength="{{ maxlength }}"{% endif %}
        {% if placeholder is defined %}placeholder="{{ placeholder }}"{% endif %}
        {% if _required %}required aria-required="true"{% endif %}
        {% if _disabled %}disabled aria-disabled="true"{% endif %}
        {% if _readonly %}readonly aria-readonly="true"{% endif %}
        {% if _hasError %}aria-invalid="true"{% else %}aria-invalid="false"{% endif %}
        {% if _described is not empty %}aria-describedby="{{ _described|join(' ') }}"{% endif %}
        class="
            w-full rounded-lg border bg-white text-sm text-zinc-900 px-3 py-2
            placeholder:text-zinc-400
            focus:outline-none focus:ring-2 focus:ring-offset-0 focus:ring-zinc-900
            transition-colors
            {{ _resizeClass }}
            {{ _hasError
                ? 'border-red-400 focus:ring-red-500 bg-red-50'
                : 'border-zinc-300 hover:border-zinc-400' }}
            {{ _disabled ? 'opacity-50 cursor-not-allowed bg-zinc-50' : '' }}
            {{ _readonly ? 'bg-zinc-50 cursor-default' : '' }}
        "
    >{{ value|default('') }}</textarea>

    {# Bas : aide + compteur #}
    <div class="flex items-start justify-between gap-4">
        <div class="flex flex-col gap-1">
            {% if _hasHelp %}
                <p id="{{ _helpId }}" class="text-xs text-zinc-500">{{ help }}</p>
            {% endif %}
            {% if _hasError %}
                <p
                    id="{{ _errorId }}"
                    class="text-xs text-red-600 flex items-center gap-1"
                    role="alert"
                    aria-live="polite"
                >
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16" aria-hidden="true">
                        <circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 11v.5"/>
                    </svg>
                    {{ error }}
                </p>
            {% endif %}
        </div>

        {# Compteur de caractères #}
        {% if _hasMax %}
            <p
                id="{{ _countId }}"
                class="text-xs text-zinc-400 shrink-0 tabular-nums"
                aria-live="polite"
                aria-atomic="true"
            >
                <span id="{{ _id }}-current">{{ value|default('')|length }}</span> / {{ maxlength }}
            </p>
            <script>
                (function () {
                    var ta  = document.getElementById('{{ _id }}');
                    var cur = document.getElementById('{{ _id }}-current');
                    var max = {{ maxlength }};
                    ta.addEventListener('input', function () {
                        var len = ta.value.length;
                        cur.textContent = len;
                        cur.closest('p').classList.toggle('text-red-500', len >= max);
                        cur.closest('p').classList.toggle('text-zinc-400', len < max);
                    });
                })();
            </script>
        {% endif %}
    </div>

</div>
