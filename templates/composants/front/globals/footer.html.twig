{#
Footer component — site public
Usage : {% include 'components/footer.html.twig' %}
#}
<footer class="bg-zinc-950 text-zinc-400 mt-24">
    <div class="max-w-6xl mx-auto px-6 py-16">

        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-12 border-b border-zinc-800">

            {# Colonne 1 : identité #}
            <div class="md:col-span-2">
                <div class="flex items-center gap-2.5 mb-4">
                    <div class="w-7 h-7 rounded-lg bg-white flex items-center justify-center">
                        <svg class="w-4 h-4 fill-zinc-900" viewBox="0 0 16 16">
                            <path d="M8 1L14 5v6l-6 4L2 11V5z"/>
                        </svg>
                    </div>
                    <span class="text-sm font-semibold text-white">{{ site_name|default('AssocDev') }}</span>
                </div>
                <p class="text-sm leading-relaxed max-w-xs">
                    Nous accompagnons les associations et les jeunes entreprises dans leur développement,
                    de la structuration à la mise en œuvre de leurs projets.
                </p>
                {# Réseaux sociaux #}
                <div class="flex gap-3 mt-6">
                    {% for social in [
                        { label: 'LinkedIn', href: '#', icon: 'linkedin' },
                        { label: 'Twitter',  href: '#', icon: 'twitter' },
                        { label: 'Email',    href: 'mailto:contact@assocdev.fr', icon: 'mail' },
                    ] %}
                        <a href="{{ social.href }}"
                           class="w-8 h-8 rounded-lg border border-zinc-700 flex items-center justify-center hover:border-zinc-500 hover:text-zinc-200 transition-colors"
                           aria-label="{{ social.label }}">
                            {% if social.icon == 'linkedin' %}
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M1.5 2.5a1 1 0 112 0 1 1 0 01-2 0zM1 5h2v9H1zm4 0h1.9v1.2h.03C7.4 5.6 8.4 5 9.8 5 12 5 13 6.3 13 8.6V14h-2v-5c0-.9-.3-1.7-1.3-1.7-1.1 0-1.7.8-1.7 1.7V14H5V5z"/></svg>
                            {% elseif social.icon == 'twitter' %}
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M14.3 1H12l-3.1 4L5.7 1H1l5.7 7.3L1.3 15H3.6l3.4-4.3 3.4 4.3H15l-5.9-7.5L14.3 1z"/></svg>
                            {% elseif social.icon == 'mail' %}
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><rect x="1" y="3" width="14" height="10" rx="1"/><path d="M1 4l7 5 7-5"/></svg>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>

            {# Colonne 2 : navigation #}
            <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">Navigation</p>
                <ul class="space-y-2 text-sm">
                    {% for link in [
                        { label: 'Accueil',    href: path('app_front_page_home') },
                        { label: 'Services',   href: path('app_front_page_home') },
                        { label: 'À propos',   href: path('app_front_page_home') },
                        { label: 'Actualités', href: path('app_front_page_home') },
                        { label: 'Contact',    href: path('app_front_page_home') },
                    ] %}
                        <li>
                            <a href="{{ link.href }}" class="hover:text-zinc-200 transition-colors">
                                {{ link.label }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {# Colonne 3 : contact #}
            <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">Contact</p>
                <ul class="space-y-3 text-sm">
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 shrink-0 mt-0.5 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M8 1a5 5 0 00-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 00-5-5zm0 6.5a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/></svg>
                        <span>12 rue des Associations<br>75000 Paris</span>
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 shrink-0 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><rect x="1" y="3" width="14" height="10" rx="1"/><path d="M1 4l7 5 7-5"/></svg>
                        <a href="mailto:contact@assocdev.fr" class="hover:text-zinc-200 transition-colors">
                            contact@assocdev.fr
                        </a>
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 shrink-0 text-zinc-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M2 3h3l1.5 3-1.5 1.5a9 9 0 004.5 4.5L11 10.5l3 1.5v3a1 1 0 01-1 1A13 13 0 012 3z"/></svg>
                        <a href="tel:+33123456789" class="hover:text-zinc-200 transition-colors">
                            +33 1 23 45 67 89
                        </a>
                    </li>
                </ul>
            </div>

        </div>

        {# Bas de footer #}
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8 text-xs">
            <p>© {{ "now"|date("Y") }} {{ site_name|default('AssocDev') }}. Tous droits réservés.</p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-zinc-200 transition-colors">Mentions légales</a>
                <a href="#" class="hover:text-zinc-200 transition-colors">Politique de confidentialité</a>
            </div>
        </div>

    </div>
</footer>
