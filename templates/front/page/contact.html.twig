{% extends 'base.html.twig' %}

{% block title %}Développement & Accompagnement des associations et jeunes entreprises{% endblock %}
{% block meta_description %}Nous accompagnons les associations et jeunes entreprises dans leur structuration, leur développement et la mise en œuvre de leurs projets.{% endblock %}

{% block content %}

{# ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ #}
    <section class="relative overflow-hidden border-b border-zinc-100">

        {# Grille de fond décorative #}
        <div style="position:absolute;inset:0;background-image:linear-gradient(to right,#f4f4f580 1px,transparent 1px),linear-gradient(to bottom,#f4f4f580 1px,transparent 1px);background-size:48px 48px;pointer-events:none;"></div>

        <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-40">
            <div class="max-w-3xl">

                {# Badge #}
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-zinc-200 bg-zinc-50 text-xs font-medium text-zinc-600 mb-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    Associations & jeunes entreprises
                </div>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-zinc-900 leading-tight mb-6">
                    Donnez vie à vos<br>
                    <span class="text-zinc-400">projets collectifs</span>
                </h1>
                <p class="text-lg text-zinc-500 leading-relaxed max-w-xl mb-10">
                    Nous accompagnons les associations et les jeunes entreprises dans leur structuration,
                    leur développement et la concrétisation de leurs ambitions — de l'idée à l'action.
                </p>

                <div class="flex flex-wrap items-center gap-3">
                    <a href="{{ path('app_front_page_home') }}"
                       class="inline-flex items-center gap-2 h-11 px-6 text-sm font-medium rounded-xl
                          bg-zinc-900 text-white hover:bg-zinc-700 transition-colors">
                        Démarrer un projet
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                    </a>
                    <a href="{{ path('app_front_page_home') }}"
                       class="inline-flex items-center gap-2 h-11 px-6 text-sm font-medium rounded-xl
                          border border-zinc-200 text-zinc-600 hover:bg-zinc-50 transition-colors">
                        Découvrir nos services
                    </a>
                </div>

            </div>

            {# Chiffres clés flottants #}
            <div class="grid grid-cols-3 gap-4 mt-16 max-w-lg">
                {% for stat in [
                    { value: '200+',  label: 'structures accompagnées' },
                    { value: '8 ans', label: "d'expérience" },
                    { value: '95 %',  label: 'de satisfaction' },
                ] %}
                    <div class="bg-white border border-zinc-200 rounded-xl p-4 text-center">
                        <p class="text-2xl font-semibold text-zinc-900">{{ stat.value }}</p>
                        <p class="text-xs text-zinc-500 mt-1">{{ stat.label }}</p>
                    </div>
                {% endfor %}
            </div>

        </div>
    </section>

    {# ═══════════════════════════════════════════
   SERVICES
═══════════════════════════════════════════ #}
    <section id="services" class="py-24 bg-white">
        <div class="max-w-6xl mx-auto px-6">

            {# En-tête de section #}
            <div class="max-w-xl mb-14">
                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-3">Ce que nous faisons</p>
                <h2 class="text-3xl font-semibold tracking-tight text-zinc-900 mb-4">
                    Un accompagnement adapté à chaque étape
                </h2>
                <p class="text-zinc-500 leading-relaxed">
                    Que vous soyez une association en devenir ou une jeune entreprise en phase de lancement,
                    nous avons un programme conçu pour vous.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                {% set services = services|default([
                    {
                        icon: 'structure',
                        title: 'Structuration juridique',
                        desc: "Création de statuts, choix de la forme juridique, formalités administratives — nous vous guidons pas à pas dans la création de votre structure.",
                        tag: 'Associations & entreprises',
                    },
                    {
                        icon: 'strategy',
                        title: 'Stratégie & développement',
                        desc: "Élaboration de votre plan d'action, identification des leviers de croissance et construction d'une feuille de route opérationnelle.",
                        tag: 'Développement',
                    },
                    {
                        icon: 'finance',
                        title: 'Financement & subventions',
                        desc: "Recherche de financements publics et privés, montage de dossiers de subventions, mise en relation avec des partenaires financeurs.",
                        tag: 'Associations',
                    },
                    {
                        icon: 'communication',
                        title: 'Communication',
                        desc: "Construction de votre identité visuelle, stratégie de communication et présence digitale adaptées à vos ressources et objectifs.",
                        tag: 'Associations & entreprises',
                    },
                    {
                        icon: 'formation',
                        title: 'Formation & montée en compétences',
                        desc: "Ateliers pratiques, webinaires et formations sur mesure pour renforcer les savoir-faire de vos équipes et bénévoles.",
                        tag: 'Formation',
                    },
                    {
                        icon: 'reseau',
                        title: 'Mise en réseau',
                        desc: "Accès à notre communauté de structures partenaires, événements de rencontre et opportunités de collaboration.",
                        tag: 'Réseau',
                    },
                ]) %}

                {% for service in services %}
                    <div class="group bg-white border border-zinc-200 rounded-2xl p-6 hover:border-zinc-400 hover:shadow-sm transition-all duration-200">

                        {# Icône #}
                        <div class="w-10 h-10 rounded-xl bg-zinc-100 flex items-center justify-center mb-5 group-hover:bg-zinc-900 transition-colors duration-200">
                            {% if service.icon == 'structure' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><path d="M9 11.5h5M11.5 9v5"/></svg>
                            {% elseif service.icon == 'strategy' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M2 12l3.5-4 3 3L13 4"/><circle cx="13" cy="4" r="1.5"/></svg>
                            {% elseif service.icon == 'finance' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6"/><path d="M8 5v1.5m0 3V11m-1.5-5.5h2.25A1.25 1.25 0 0110 6.75v0A1.25 1.25 0 018.75 8H7.25A1.25 1.25 0 006 9.25v0A1.25 1.25 0 007.25 10.5H10"/></svg>
                            {% elseif service.icon == 'communication' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M2 3h12a1 1 0 011 1v7a1 1 0 01-1 1H5l-3 2V4a1 1 0 011-1z"/></svg>
                            {% elseif service.icon == 'formation' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><path d="M1 4l7 3 7-3-7-3-7 3z"/><path d="M4 5.5v4c0 1.5 4 3 4 3s4-1.5 4-3v-4"/><path d="M14 4v5"/></svg>
                            {% elseif service.icon == 'reseau' %}
                                <svg class="w-5 h-5 text-zinc-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 16 16"><circle cx="8" cy="4" r="2"/><circle cx="3" cy="12" r="2"/><circle cx="13" cy="12" r="2"/><path d="M8 6v2M6.3 10.5L4 11M9.7 10.5L12 11"/></svg>
                            {% endif %}
                        </div>

                        <span class="inline-block text-[10px] font-medium px-2 py-0.5 rounded-full bg-zinc-100 text-zinc-500 mb-3">
                        {{ service.tag }}
                    </span>
                        <h3 class="text-sm font-semibold text-zinc-900 mb-2">{{ service.title }}</h3>
                        <p class="text-sm text-zinc-500 leading-relaxed">{{ service.desc }}</p>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-10 text-center">
                <a href="{{ path('app_front_page_home') }}"
                   class="inline-flex items-center gap-2 text-sm font-medium text-zinc-600 hover:text-zinc-900 transition-colors">
                    Voir tous nos services
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </a>
            </div>

        </div>
    </section>

    {# ═══════════════════════════════════════════
   ACTUALITÉS
═══════════════════════════════════════════ #}
    <section id="actualites" class="py-24 bg-zinc-50 border-y border-zinc-100">
        <div class="max-w-6xl mx-auto px-6">

            <div class="flex items-end justify-between gap-4 mb-12">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-3">Blog & ressources</p>
                    <h2 class="text-3xl font-semibold tracking-tight text-zinc-900">Dernières actualités</h2>
                </div>
                <a href="{{ path('app_front_page_home') }}"
                   class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors shrink-0">
                    Tout voir
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                {% for article in articles|default([
                    {
                        category: 'Associations',
                        date: '28 avril 2026',
                        title: 'Comment structurer votre association en 5 étapes clés',
                        excerpt: "De la rédaction des statuts à l'ouverture d'un compte bancaire, voici le parcours complet pour démarrer sereinement.",
                        slug: 'structurer-association-5-etapes',
                        read_time: '5 min',
                    },
                    {
                        category: 'Jeunes entreprises',
                        date: '15 avril 2026',
                        title: 'Les financements publics méconnus pour les startups sociales',
                        excerpt: "Tour d'horizon des dispositifs d'aide auxquels vous pouvez prétendre et conseils pour maximiser vos chances d'obtention.",
                        slug: 'financements-startups-sociales',
                        read_time: '7 min',
                    },
                    {
                        category: 'Ressource',
                        date: '3 avril 2026',
                        title: 'Bénévolat et engagement : comment fidéliser vos équipes ?',
                        excerpt: "Les clés pour créer un environnement motivant et durable au sein de votre structure associative.",
                        slug: 'fideliser-benevoles',
                        read_time: '4 min',
                    },
                ]) %}
                    <article class="bg-white border border-zinc-200 rounded-2xl overflow-hidden hover:border-zinc-300 hover:shadow-sm transition-all duration-200 flex flex-col">

                        {# Placeholder image #}
                        <div class="h-40 bg-zinc-100 flex items-center justify-center border-b border-zinc-100">
                            <svg class="w-8 h-8 text-zinc-300" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                            </svg>
                        </div>

                        <div class="p-5 flex flex-col flex-1">
                            <div class="flex items-center gap-2 mb-3">
                            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-zinc-100 text-zinc-500">
                                {{ article.category }}
                            </span>
                                <span class="text-[10px] text-zinc-400">{{ article.read_time }} de lecture</span>
                            </div>
                            <h3 class="text-sm font-semibold text-zinc-900 leading-snug mb-2">{{ article.title }}</h3>
                            <p class="text-xs text-zinc-500 leading-relaxed flex-1">{{ article.excerpt }}</p>
                            <div class="flex items-center justify-between mt-4 pt-4 border-t border-zinc-100">
                                <span class="text-[11px] text-zinc-400">{{ article.date }}</span>
                                <a href="{{ path('app_front_page_home', { slug: article.slug }) }}"
                                   class="text-xs font-medium text-zinc-600 hover:text-zinc-900 transition-colors inline-flex items-center gap-1">
                                    Lire
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>

        </div>
    </section>

    {# ═══════════════════════════════════════════
   PARTENAIRES
═══════════════════════════════════════════ #}
    <section id="partenaires" class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-6">

            <div class="text-center mb-12">
                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-400 mb-3">Ils nous font confiance</p>
                <h2 class="text-2xl font-semibold tracking-tight text-zinc-900">Nos partenaires</h2>
            </div>

            {# Logos partenaires — remplacer par de vrais logos via une variable Twig #}
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                {% for partner in partners|default([
                    { name: 'Fondation A' },
                    { name: 'Réseau B' },
                    { name: 'Agence C' },
                    { name: 'Institut D' },
                    { name: 'Fédération E' },
                    { name: 'Collectif F' },
                ]) %}
                    <div class="h-16 border border-zinc-200 rounded-xl flex items-center justify-center px-4 hover:border-zinc-300 transition-colors">
                        {% if partner.logo is defined %}
                            <img src="{{ partner.logo }}" alt="{{ partner.name }}" class="h-7 w-auto object-contain grayscale hover:grayscale-0 transition">
                        {% else %}
                            <span class="text-xs font-medium text-zinc-400">{{ partner.name }}</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

        </div>
    </section>

    {# ═══════════════════════════════════════════
   CONTACT / CTA
═══════════════════════════════════════════ #}
    <section id="contact" class="py-24 bg-zinc-950">
        <div class="max-w-6xl mx-auto px-6">
            <div class="max-w-2xl mx-auto text-center">

                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-500 mb-4">Parlons de votre projet</p>
                <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white mb-6">
                    Prêt à franchir<br>le prochain cap ?
                </h2>
                <p class="text-zinc-400 leading-relaxed mb-10">
                    Un échange de 30 minutes suffit souvent pour identifier les premières actions concrètes.
                    Notre équipe est à votre disposition pour répondre à vos questions.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                    <a href="{{ path('app_front_page_home') }}"
                       class="inline-flex items-center gap-2 h-11 px-8 text-sm font-medium rounded-xl
                          bg-white text-zinc-900 hover:bg-zinc-100 transition-colors">
                        Prendre rendez-vous
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                    </a>
                    <a href="mailto:contact@assocdev.fr"
                       class="inline-flex items-center gap-2 h-11 px-8 text-sm font-medium rounded-xl
                          border border-zinc-700 text-zinc-400 hover:text-white hover:border-zinc-500 transition-colors">
                        contact@assocdev.fr
                    </a>
                </div>

            </div>
        </div>
    </section>

{% endblock %}
