{% extends 'base.html.twig' %}

{% block title %}Site en Maintenance - OpenPixl{% endblock %}

{% block body %}
    <div class="bg-gray-900 h-screen flex flex-col items-center justify-center text-center">
        <div class="text-white">
            <h1 class="text-4xl font-bold">Nous revenons très vite !!</h1>
            <p class="mt-4 text-lg">Nous travaillons actuellement à la refonte de notre site !</p>
        </div>
        <div class="mt-8 flex flex-col items-center justify-center">
            <form action="#" method="post" class="flex items-center">
                <input
                    type="email"
                    name="email"
                    placeholder="laissez votre email"
                    class="py-2 px-4 bg-gray-800 text-white rounded-l-md focus:outline-none"
                    required
                />
                <button
                    type="submit"
                    class="bg-blue-500 py-2 px-4 text-white rounded-r-md hover:bg-blue-600 focus:outline-none"
                >
                    S'inscrire
                </button>
            </form>
            <p class="mt-2 text-gray-400 text-sm">Soyez les premiers avertis dès le lancement de notre nouveau site !</p>
        </div>
    </div>
{% endblock %}
